<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".AppFragments.ExerciseDetailFragment">


    <ImageView
        android:id="@+id/tvExerciseDetailImg"
        android:layout_width="318dp"
        android:layout_height="317dp"
        android:layout_marginStart="46dp"
        android:layout_marginTop="15dp"
        android:layout_marginEnd="47dp"
        android:src="@drawable/log_in_image"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvExerciseDetailName" />

    <TextView
        android:id="@+id/tvExerciseDetailName"
        android:layout_width="match_parent"
        android:layout_height="68dp"
        android:layout_marginTop="66dp"
        android:text="Jumping Jacks"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:textSize="22sp"
        android:gravity="center"
        android:textStyle="bold"/>

    <TextView
        android:id="@+id/tvExerciseDetailInfo"
        android:layout_width="147dp"
        android:layout_height="62dp"
        android:layout_marginStart="46dp"
        android:layout_marginTop="36dp"
        android:layout_marginEnd="54dp"
        android:layout_marginBottom="167dp"
        android:text="00:29"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/btnDone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvExerciseDetailImg"
        android:gravity="center"
        android:textStyle="italic"
        android:textSize="22sp"/>

    <Button
        android:id="@+id/btnDone"
        android:layout_width="117dp"
        android:layout_height="66dp"
        android:layout_marginStart="54dp"
        android:layout_marginTop="36dp"
        android:layout_marginBottom="163dp"
        android:text="Done "
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@+id/tvExerciseDetailInfo"
        app:layout_constraintTop_toBottomOf="@+id/tvExerciseDetailImg" />

    <Button
        android:id="@+id/btnBackDetail"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="18dp"
        android:layout_marginEnd="307dp"
        android:text="Back"
        app:layout_constraintBottom_toTopOf="@+id/tvExerciseDetailName"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>